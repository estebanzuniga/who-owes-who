generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())

  coupleAccountAsCreator CoupleAccount[] @relation("CreatorUser")
  coupleAccountAsInvited CoupleAccount[] @relation("InvitedUser")

  refreshTokens    RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model CoupleAccount {
  id        String   @id @default(cuid())
  currency  String   @default("CLP")
  createdAt DateTime @default(now())

  creatorId String
  creator   User    @relation("CreatorUser", fields: [creatorId], references: [id])

  invitedId String?
  invited   User?   @relation("InvitedUser", fields: [invitedId], references: [id])

  invite     CoupleInvite?

  @@index([creatorId])
  @@index([invitedId])
}

model CoupleInvite {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  expiresAt DateTime
  usedAt    DateTime?

  coupleId String        @unique
  couple   CoupleAccount @relation(fields: [coupleId], references: [id], onDelete: Cascade)
}
